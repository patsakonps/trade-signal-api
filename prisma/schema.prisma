generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndicatorTemplateType {
  CUSTOM_SCRIPT
}

enum RuleIndicatorType {
  BUILT_IN
  CUSTOM_SCRIPT
}

model Workspace {
  id                   String                       @id
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  watchlist            WatchlistItem[]
  indicators           IndicatorTemplate[]
  rules                SignalRule[]
  signals              Signal[]
  trades               Trade[]
  holdings             Holding[]
  importJobs           ImportJob[]
  telegramNotification TelegramNotificationSetting?
  backtestRuns         BacktestRun[]
}

model WatchlistItem {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  exchange    String      @default("BINANCE")
  symbol      String
  timeframe   String
  createdAt   DateTime    @default(now())

  @@unique([workspaceId, exchange, symbol, timeframe])
  @@index([workspaceId])
}

model IndicatorTemplate {
  id                  String                @id @default(cuid())
  workspaceId          String
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                 String
  key                  String
  type                 IndicatorTemplateType @default(CUSTOM_SCRIPT)
  script               String                @db.Text
  paramsJson           Json                  @default("{}")
  outputSchemaVersion  Int                   @default(1)
  enabled              Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  rules                SignalRule[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model SignalRule {
  id                   String             @id @default(cuid())
  workspaceId           String
  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                  String
  exchange              String             @default("BINANCE")
  symbol                String
  timeframe             String
  indicatorType         RuleIndicatorType   @default(BUILT_IN)
  indicatorKey          String
  indicatorTemplateId   String?
  indicatorTemplate     IndicatorTemplate?  @relation(fields: [indicatorTemplateId], references: [id], onDelete: SetNull)
  condition             String             @default("BUY_OR_SELL")
  enabled               Boolean            @default(true)
  paramsJson            Json               @default("{}")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  signals               Signal[]
  backtestRuns          BacktestRun[]

  @@index([workspaceId])
  @@index([workspaceId, symbol, timeframe])
}

model Signal {
  id              String      @id @default(cuid())
  workspaceId      String
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalRuleId     String?
  signalRule       SignalRule? @relation(fields: [signalRuleId], references: [id], onDelete: SetNull)
  exchange         String      @default("BINANCE")
  symbol           String
  timeframe        String
  indicatorKey     String
  signalType       String
  zone             String?
  price            Decimal     @db.Decimal(30, 12)
  candleCloseTime  DateTime
  payloadJson      Json        @default("{}")
  createdAt        DateTime    @default(now())

  @@unique([workspaceId, signalRuleId, signalType, candleCloseTime])
  @@index([workspaceId])
  @@index([workspaceId, symbol, timeframe])
}

model TelegramNotificationSetting {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chatId      String?
  enabled     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Trade {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  exchange    String
  symbol      String
  side        String
  price       Decimal   @db.Decimal(30, 12)
  quantity    Decimal   @db.Decimal(30, 12)
  fee         Decimal?  @db.Decimal(30, 12)
  feeAsset    String?
  tradedAt    DateTime
  source      String    @default("MANUAL")
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model Holding {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  asset        String
  quantity     Decimal   @db.Decimal(30, 12)
  avgCost      Decimal   @db.Decimal(30, 12)
  realizedPnl  Decimal   @default(0) @db.Decimal(30, 12)
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, asset])
  @@index([workspaceId])
}

model ImportJob {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source      String
  fileName    String
  status      String    @default("COMPLETED")
  summaryJson Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}


model BacktestRun {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ruleId          String
  rule            SignalRule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  exchange        String          @default("BINANCE")
  symbol          String
  timeframe       String

  initialCapital  Float
  finalCapital    Float
  netProfitPct    Float
  winrate         Float
  maxDrawdownPct  Float
  profitFactor    Float
  totalTrades     Int
  winningTrades   Int             @default(0)
  losingTrades    Int             @default(0)
  avgWinPct       Float           @default(0)
  avgLossPct      Float           @default(0)
  expectancyPct   Float           @default(0)
  score           Float           @default(0)
  configJson      Json            @default("{}")
  createdAt       DateTime        @default(now())

  trades          BacktestTrade[]

  @@index([workspaceId])
  @@index([workspaceId, ruleId])
  @@index([workspaceId, score])
}

model BacktestTrade {
  id              String       @id @default(cuid())
  backtestRunId   String
  run             BacktestRun  @relation(fields: [backtestRunId], references: [id], onDelete: Cascade)
  side            String
  entryTime       DateTime
  entryPrice      Float
  exitTime        DateTime
  exitPrice       Float
  quantity        Float
  entryFee        Float        @default(0)
  exitFee         Float        @default(0)
  pnl             Float
  pnlPct          Float
  reason          String
  createdAt       DateTime     @default(now())

  @@index([backtestRunId])
}
